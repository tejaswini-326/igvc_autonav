<?xml version='1.0'?>

<robot name="mogi_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- STEP 5 - Gazebo plugin -->
  <xacro:include filename="$(find bme_gazebo_sensors)/urdf/mogi_bot.gazebo" />

  <!-- STEP 4 - RViz colors -->
  <xacro:include filename="$(find bme_gazebo_sensors)/urdf/materials.xacro" />

  <!-- STEP 1 - Robot footprint -->
  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.235" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="base_link" />
  </joint>

  <link name='base_link'>
    <inertial>
      <mass value="15.0" />
      <origin xyz="0.0 0 0.35" rpy="0 0 0" />
      <inertia
        ixx="0.0625" ixy="0" ixz="0"
        iyy="0.2125" iyz="0"
        izz="0.25"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="1.375 1 .35" />
      </geometry>
    </collision>

    <visual name='base_link_visual'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="1.375 1 .35" />
      </geometry>
    </visual>
  </link>

  <joint
    type="continuous" name="left_wheel_joint">
    <origin xyz="0 .55 -.15" rpy="0 0 0" />
    <child link="wheel_left" />
    <parent link="base_link" />
    <axis xyz="0 1 0" />
    <limit effort="100" velocity="10" />
    <dynamics damping="1.0" friction="1.0" />
  </joint>

  <link name='wheel_left'>
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".1875" length=".1" />
      </geometry>
    </collision>

    <visual name='left_wheel_visual'>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".1875" length=".1" />
      </geometry>
    </visual>
  </link>

  <joint
    type="continuous" name="right_wheel_joint">
    <origin xyz="0 -.55 -.15" rpy="0 0 0" />
    <child link="wheel_right" />
    <parent link="base_link" />
    <axis xyz="0 1 0" />
    <limit effort="100" velocity="10" />
    <dynamics damping="1.0" friction="1.0" />
  </joint>

  <link name='wheel_right'>
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".1875" length=".1" />
      </geometry>
    </collision>

    <visual name='right_wheel_visual'>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".1875" length=".1" />
      </geometry>
    </visual>
  </link>

  <joint
    type="fixed" name="linkf">
    <origin xyz=".65 0 -.19625" rpy="0 0 0" />
    <child link="f_link" />
    <parent link="base_link" />
  </joint>

  <link name="f_link">
    <inertial>
      <mass value=".1" />
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <geometry>
        <cylinder radius=".02" length=".045" />
      </geometry>
    </collision>

    <visual name='flinkvisual'>
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <geometry>
        <cylinder radius=".02" length=".045" />
      </geometry>
    </visual>

  </link>

  <joint
    type="continuous" name="front_castor">
    <origin xyz=".65 0 -.2775" rpy="0 0 0" />
    <child link="castor_front" />
    <parent link="base_link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="10" />
    <dynamics damping="1.0" friction="1.0" />
  </joint>

  <link name="castor_front">
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".06" length=".03" />
      </geometry>
    </collision>

    <visual name='front_castor_visual'>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".06" length=".03" />
      </geometry>
    </visual>
  </link>

  <joint
    type="fixed" name="linkb">
    <origin xyz="-.65 0 -.19625" rpy="0 0 0" />
    <child link="b_link" />
    <parent link="base_link" />
  </joint>

  <link name="b_link">
    <inertial>
      <mass value=".1" />
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <geometry>
        <cylinder radius=".02" length=".045" />
      </geometry>
    </collision>

    <visual name='blinkvisual'>
      <origin xyz="0 0 0" rpy="0 0 1.5707" />
      <geometry>
        <cylinder radius=".02" length=".045" />
      </geometry>
    </visual>

  </link>

  <joint
    type="continuous" name="back_castor">
    <origin xyz="-.65 0 -.2775" rpy="0 0 0" />
    <child link="castor_back" />
    <parent link="base_link" />
    <axis xyz="0 0 1" />
    <limit effort="100" velocity="10" />
    <dynamics damping="1.0" friction="1.0" />
  </joint>

  <link name="castor_back">
    <inertial>
      <mass value="5.0" />
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <inertia
        ixx="0.014" ixy="0" ixz="0"
        iyy="0.014" iyz="0"
        izz="0.025"
      />
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".06" length=".03" />
      </geometry>
    </collision>

    <visual name='back_castor_visual'>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707" />
      <geometry>
        <cylinder radius=".06" length=".03" />
      </geometry>
    </visual>
  </link>

  <joint
    type="fixed" name="sensor_mount">
    <origin xyz=".4 0 .6" rpy="0 0 0" />
    <child link="stick" />
    <parent link="base_link" />
  </joint>

  <link name="stick">
    <inertial>
      <mass value="1.0" />
      <origin xyz="0.0 0 0" rpy="0 0 0" />
      <inertia
        ixx="0.0625" ixy="0" ixz="0"
        iyy="0.2125" iyz="0"
        izz="0.25"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size=".0625 .0625 .9" />
      </geometry>
    </collision>

    <visual name='sensor_mount_visual'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size=".0625 .0625 .9" />
      </geometry>
    </visual>
  </link>

  <joint
    type="fixed" name="lidar">
    <origin xyz=".59375 0 .3" rpy="0 0 0" />
    <child link="scan_link" />
    <parent link="base_link" />
  </joint>

  <link name="scan_link">
    <inertial>
      <mass value="1.0" />
      <origin xyz="0.0 0 0" rpy="0 0 0" />
      <inertia
        ixx="0.0625" ixy="0" ixz="0"
        iyy="0.2125" iyz="0"
        izz="0.25"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size=".125 .125 .05" />
      </geometry>
    </collision>

    <visual name='sensor_mount_visual'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size=".125 .125 .05" />
      </geometry>
    </visual>

  </link>


  <joint
    type="fixed" name="camera">
    <origin xyz="0 0 .45" rpy="0 0 0" />
    <child link="camera_link" />
    <parent link="stick" />
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="1.0" />
      <origin xyz="0.0 0 0" rpy="0 .25 0" />
      <inertia
        ixx="0.0625" ixy="0" ixz="0"
        iyy="0.2125" iyz="0"
        izz="0.25"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size=".075 .25 .075" />
      </geometry>
    </collision>

    <visual name='cam_visual'>
      <origin xyz="0 0 0" rpy="0 .25 0" />
      <geometry>
        <box size=".075 .25 .075" />
      </geometry>
    </visual>

  </link>

</robot>
